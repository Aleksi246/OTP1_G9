<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.AdminController">
    <top>
        <fx:include source="topbar.fxml" />
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <HBox spacing="10">
                <Label text="Admin Dashboard" />
                <Button text="Logout" onAction="#handleLogout" />
            </HBox>

            <Label text="Register New Teacher" />

            <TextField fx:id="teacherUsernameField" promptText="Teacher Username" />
            <TextField fx:id="teacherPasswordField" promptText="Teacher Password" />

            <Button text="Create Teacher" onAction="#handleCreateTeacher" />

            <Label fx:id="statusLabel" text="" wrapText="true" />
            <Label fx:id="errorLabel" text="" wrapText="true" />
        </VBox>
    </center>
</BorderPane>
