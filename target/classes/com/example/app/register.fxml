<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f0f2f5; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.RegisterController">
    <children>
        <VBox alignment="CENTER_LEFT" maxWidth="450.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 15, 0, 0, 8);">
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>
            <children>

                <VBox spacing="5.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Create Account">
                            <font>
                                <Font size="30.0" />
                            </font>
                        </Label>
                        <Label style="-fx-text-fill: #7f8c8d;" text="Join our learning platform today." />
                    </children>
                </VBox>

                <Separator prefWidth="200.0" />

                <VBox spacing="15.0">
                    <children>
                        <TextField fx:id="usernameField" prefHeight="45.0" promptText="Username" style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />

                        <TextField fx:id="emailField" prefHeight="45.0" promptText="Email Address" style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />

                        <StackPane alignment="CENTER_RIGHT">
                            <children>
                                <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="New Password" style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />

                                <TextField fx:id="passwordTextField" managed="false" prefHeight="45.0" style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" visible="false" />

                                <Button fx:id="toggleButton" onAction="#togglePassword" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #95a5a6;" text="👁">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                    <StackPane.margin>
                                        <Insets right="10.0" />
                                    </StackPane.margin>
                                </Button>
                            </children>
                        </StackPane>

                        <PasswordField fx:id="confirmPasswordField" prefHeight="45.0" promptText="Confirm Password" style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />
                    </children>
                </VBox>

                <Label fx:id="messageLabel" minHeight="20.0" style="-fx-text-fill: #e74c3c;" wrapText="true">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>

                <VBox spacing="15.0">
                    <children>
                        <Button fx:id="registerButton" maxWidth="Infinity" onAction="#handleRegister" prefHeight="45.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Sign Up">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Button>

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Already have an account?" style="-fx-text-fill: #7f8c8d;" />
                                <Hyperlink onAction="#handleSwitchContext" style="-fx-text-fill: #2980b9; -fx-font-weight: bold;" text="Log In" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>