@creatorUserId = 166
@user2Id = 167
@user3Id = 168
@classId = 96
@materialId = 1
@reviewId = 1

### ==============================
### 1) Register users (email-based)
### ==============================

### Register creator
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "{{creatorUsername}}",
  "email": "{{creatorEmail}}",
  "password": "{{creatorPassword}}"
}

### Register user2
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "{{user2Username}}",
  "email": "{{user2Email}}",
  "password": "{{user2Password}}"
}

### Register user3
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "{{user3Username}}",
  "email": "{{user3Email}}",
  "password": "{{user3Password}}"
}

### ==============================
### 2) Login (email OR username + password)
### ==============================

### Login creator
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{creatorEmail}}",
  "password": "{{creatorPassword}}"
}

### Login user2
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{user2Username}}",
  "password": "{{user2Password}}"
}

### Login user3
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user3Email}}",
  "password": "{{user3Password}}"
}

### ======================================
### 3) Users endpoints (protected)
### ======================================

### Get all users
GET {{baseUrl}}/api/users
Authorization: Bearer {{creatorToken}}

### Get creator user by ID
GET {{baseUrl}}/api/users/{{creatorUserId}}
Authorization: Bearer {{creatorToken}}

### ======================================
### 4) Courses (creator-owned)
### ======================================

### Create course as creator (creator_id auto-set)
POST {{baseUrl}}/api/courses
Authorization: Bearer {{creatorToken}}
Content-Type: application/json

{
  "className": "API Test Course Creator Owned",
  "topic": "integration"
}

### Get all courses
GET {{baseUrl}}/api/courses
Authorization: Bearer {{creatorToken}}

### Get course by ID
GET {{baseUrl}}/api/courses/{{classId}}
Authorization: Bearer {{creatorToken}}

### Update course as creator (allowed)
PUT {{baseUrl}}/api/courses/{{classId}}
Authorization: Bearer {{creatorToken}}
Content-Type: application/json

{
  "topic": "integration-updated"
}

### Update course as non-creator (expected 403)
PUT {{baseUrl}}/api/courses/{{classId}}
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{
  "topic": "should-fail"
}

### =====================================================
### 5) Participants (creator enrolls; users can unenroll themselves)
### =====================================================

### Enroll user2 by creator (allowed)
POST {{baseUrl}}/api/participants/enroll
Authorization: Bearer {{creatorToken}}
Content-Type: application/json

{
  "userId": {{user2Id}},
  "classId": {{classId}}
}

### Enroll user3 by non-creator (expected 403)
POST {{baseUrl}}/api/participants/enroll
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{
  "userId": {{user3Id}},
  "classId": {{classId}}
}

### Get users by class
GET {{baseUrl}}/api/participants/class/{{classId}}
Authorization: Bearer {{creatorToken}}

### Get classes by user2
GET {{baseUrl}}/api/participants/user/{{user2Id}}
Authorization: Bearer {{user2Token}}

### Unenroll user2 by non-creator (self-unenroll, allowed)
DELETE {{baseUrl}}/api/participants/unenroll
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{
  "userId": {{user2Id}},
  "classId": {{classId}}
}

### Unenroll user2 by different non-creator (expected 403)
DELETE {{baseUrl}}/api/participants/unenroll
Authorization: Bearer {{user3Token}}
Content-Type: application/json

{
  "userId": {{user2Id}},
  "classId": {{classId}}
}

### ======================================
### 6) Materials (only class creator can upload/update/delete)
### ======================================

### Upload material as creator (allowed)
POST {{baseUrl}}/api/materials
Authorization: Bearer {{creatorToken}}
Content-Type: multipart/form-data; boundary=----ApiBoundary

------ApiBoundary
Content-Disposition: form-data; name="file"; filename="notes.txt"
Content-Type: text/plain

hello from http_test
------ApiBoundary
Content-Disposition: form-data; name="classId"

{{classId}}
------ApiBoundary
Content-Disposition: form-data; name="materialType"

lecture_notes
------ApiBoundary--

### Upload material as non-creator (expected 403)
POST {{baseUrl}}/api/materials
Authorization: Bearer {{user2Token}}
Content-Type: multipart/form-data; boundary=----ApiBoundary2

------ApiBoundary2
Content-Disposition: form-data; name="file"; filename="notes2.txt"
Content-Type: text/plain

should fail
------ApiBoundary2
Content-Disposition: form-data; name="classId"

{{classId}}
------ApiBoundary2
Content-Disposition: form-data; name="materialType"

lecture_notes
------ApiBoundary2--

### Get materials by course
GET {{baseUrl}}/api/materials/course/{{classId}}

### Get material by ID
GET {{baseUrl}}/api/materials/{{materialId}}

### Update material as non-creator (expected 403)
PUT {{baseUrl}}/api/materials/{{materialId}}
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{
  "materialType": "slides"
}

### Update material as creator (allowed)
PUT {{baseUrl}}/api/materials/{{materialId}}
Authorization: Bearer {{creatorToken}}
Content-Type: application/json

{
  "materialType": "slides"
}

### ======================================
### 7) Reviews (owner can update/delete own review)
### ======================================

### Create review as user2
POST {{baseUrl}}/api/reviews
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{
  "review": "Good material",
  "rating": 4,
  "fileId": {{materialId}}
}

### Get reviews by material
GET {{baseUrl}}/api/reviews/material/{{materialId}}

### Get review by ID
GET {{baseUrl}}/api/reviews/{{reviewId}}

### Update review as non-owner (expected 403)
PUT {{baseUrl}}/api/reviews/{{reviewId}}
Authorization: Bearer {{creatorToken}}
Content-Type: application/json

{
  "review": "I should not be able to update this",
  "rating": 1
}

### Update review as owner (allowed)
PUT {{baseUrl}}/api/reviews/{{reviewId}}
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{
  "review": "Updated by owner",
  "rating": 5
}

### Delete review as non-owner (expected 403)
DELETE {{baseUrl}}/api/reviews/{{reviewId}}
Authorization: Bearer {{creatorToken}}

### Delete review as owner (allowed)
DELETE {{baseUrl}}/api/reviews/{{reviewId}}
Authorization: Bearer {{user2Token}}



### ======================================
### 9) Cleanup (delete material + course)
### ======================================

### Delete material as non-creator (expected 403)
DELETE {{baseUrl}}/api/materials/{{materialId}}
Authorization: Bearer {{user2Token}}

### Delete material as creator (allowed)
DELETE {{baseUrl}}/api/materials/{{materialId}}
Authorization: Bearer {{creatorToken}}

### Delete course as non-creator (expected 403)
DELETE {{baseUrl}}/api/courses/{{classId}}
Authorization: Bearer {{user2Token}}

### Delete course as creator (allowed)
DELETE {{baseUrl}}/api/courses/{{classId}}
Authorization: Bearer {{creatorToken}}