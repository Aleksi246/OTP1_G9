<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #f0f2f5; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.MainController">

    <top>
        <VBox>
            <fx:include source="topbar.fxml" />
        </VBox>
    </top>

    <center>
        <StackPane>
            <children>
                <VBox alignment="CENTER" spacing="30.0">
                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Master New Skills Faster." textAlignment="CENTER">
                                    <font>
                                        <Font size="48.0" />
                                    </font>
                                </Label>
                                <Label maxWidth="600.0" style="-fx-text-fill: #7f8c8d;" text="Access thousands of courses from industry experts. Start your journey today and join over 5 million learners worldwide." textAlignment="CENTER" wrapText="true">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Button onAction="#onRegisterButtonClick" prefHeight="50.0" prefWidth="200.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5); -fx-cursor: hand;" text="Start Learning Now">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Button>

                        <HBox alignment="CENTER" spacing="30.0">
                            <children>
                                <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="250.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25;">
                                    <children>
                                        <Label style="-fx-font-size: 30;" text="📚" />
                                        <Label style="-fx-font-weight: bold;" text="1,000+ Courses" />
                                        <Label style="-fx-text-fill: #7f8c8d;" text="From coding to cooking." textAlignment="CENTER" wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="250.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25;">
                                    <children>
                                        <Label style="-fx-font-size: 30;" text="🎓" />
                                        <Label style="-fx-font-weight: bold;" text="Expert Tutors" />
                                        <Label style="-fx-text-fill: #7f8c8d;" text="Learn from the best." textAlignment="CENTER" wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="250.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25;">
                                    <children>
                                        <Label style="-fx-font-size: 30;" text="🏆" />
                                        <Label style="-fx-font-weight: bold;" text="Certificates" />
                                        <Label style="-fx-text-fill: #7f8c8d;" text="Validate your success." textAlignment="CENTER" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                            <VBox.margin>
                                <Insets top="20.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
