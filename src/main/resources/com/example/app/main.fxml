<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane nodeOrientation="INHERIT" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.MainController">
    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="AS_NEEDED">
            <VBox alignment="CENTER" spacing="0.0">

                <!-- Hero Section -->
                <VBox alignment="CENTER" spacing="28.0" style="-fx-background-color: #0f172a; -fx-padding: 90 60 80 60;">
                    <Label alignment="CENTER" contentDisplay="CENTER" prefWidth="700.0" style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: white;                                   -fx-font-family: 'Segoe UI', sans-serif; -fx-text-alignment: center;" text="%main.hero.title" wrapText="true" />
                    <Label prefWidth="580.0" style="-fx-font-size: 17px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI', sans-serif;                                   -fx-text-alignment: center;" text="%main.hero.subtitle" textAlignment="CENTER" wrapText="true" />
                    <HBox alignment="CENTER" spacing="14.0">
                        <Button onAction="#onRegisterButtonClick" prefHeight="50.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;                                        -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 16px;                                        -fx-padding: 0 24; -fx-font-family: 'Segoe UI', sans-serif;                                        -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.45), 16, 0, 0, 5);" text="%main.hero.getStarted" />
                        <Button onAction="#onLoginButtonClick" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #e2e8f0;                                        -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;                                        -fx-font-size: 16px; -fx-padding: 0 18; -fx-font-family: 'Segoe UI', sans-serif;                                        -fx-border-color: #475569; -fx-border-radius: 10; -fx-border-width: 1.5;" text="%main.hero.signIn" />
                    </HBox>
                </VBox>

                <!-- Feature Cards -->
                <VBox alignment="CENTER" spacing="0.0" style="-fx-background-color: #f1f5f9; -fx-padding: 60 60 70 60;">
                    <Label prefWidth="980.0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;                                   -fx-font-family: 'Segoe UI', sans-serif; -fx-padding: 0 0 32 0;" text="%main.section.title" textAlignment="CENTER" wrapText="true" />
                    <HBox alignment="CENTER" spacing="24.0">
                        <VBox alignment="TOP_CENTER" prefWidth="300.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14;                                      -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 14, 0, 0, 4);                                      -fx-padding: 28 24 28 24;">
                            <Label style="-fx-font-size: 32px; -fx-font-family: 'Segoe UI Emoji', 'Noto Color Emoji', 'EmojiOne', sans-serif;" text="" />
                            <Label maxWidth="252.0" prefWidth="252.0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;                                           -fx-font-family: 'Segoe UI', sans-serif;" text="%main.cards.library.title" textAlignment="CENTER" wrapText="true" />
                            <Label maxWidth="252.0" prefWidth="252.0" style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI', sans-serif;" text="%main.cards.library.desc" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                        <VBox alignment="TOP_CENTER" prefWidth="300.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14;                                      -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 14, 0, 0, 4);                                      -fx-padding: 28 24 28 24;">
                            <Label style="-fx-font-size: 32px; -fx-font-family: 'Segoe UI Emoji', 'Noto Color Emoji', 'EmojiOne', sans-serif;" text="" />
                            <Label maxWidth="252.0" prefWidth="252.0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;                                           -fx-font-family: 'Segoe UI', sans-serif;" text="%main.cards.instructors.title" textAlignment="CENTER" wrapText="true" />
                            <Label maxWidth="252.0" prefWidth="252.0" style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI', sans-serif;" text="%main.cards.instructors.desc" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                        <VBox alignment="TOP_CENTER" prefWidth="300.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14;                                      -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 14, 0, 0, 4);                                      -fx-padding: 28 24 28 24;">
                            <Label style="-fx-font-size: 32px; -fx-font-family: 'Segoe UI Emoji', 'Noto Color Emoji', 'EmojiOne', sans-serif;" text="" />
                            <Label maxWidth="252.0" prefWidth="252.0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;                                           -fx-font-family: 'Segoe UI', sans-serif;" text="%main.cards.reviews.title" textAlignment="CENTER" wrapText="true" />
                            <Label maxWidth="252.0" prefWidth="252.0" style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI', sans-serif;" text="%main.cards.reviews.desc" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
