<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.ClassController">

    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox alignment="TOP_LEFT" spacing="20.0" style="-fx-padding: 40;">
                <!-- Header with back button -->
                <VBox spacing="15.0">
                    <Button onAction="#handleGoBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand; -fx-pref-width: 100;" text="← Back" />
                </VBox>

                <!-- Class Details Card -->
                <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <Label fx:id="classNameLabel" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Class Name" />

                    <Label fx:id="classIdLabel" style="-fx-font-size: 16; -fx-text-fill: #3498db; -fx-font-family: 'Courier New';" text="Class ID: 0" />

                    <Label fx:id="topicLabel" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;" text="Topic: No topic" />

                    <Label fx:id="creatorLabel" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;" text="Created by: Unknown" />

                    <!-- Join Button -->
                    <Button fx:id="joinButton" onAction="#handleJoinClass" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 14;" text="Join Class" />
                </VBox>

                <!-- Content Container for future use (materials, etc.) -->
                <VBox fx:id="contentContainer" spacing="20.0" style="-fx-padding: 20;" />
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

