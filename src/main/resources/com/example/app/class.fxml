<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="900.0" minWidth="1400.0" style="-fx-background-color: #f5f7fa; -fx-font-family: 'Times New Roman';" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.ClassController">

    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20.0" style="-fx-padding: 36;">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Button onAction="#handleGoBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman';" text="← Back" />
                    <Button fx:id="joinButton" onAction="#handleJoinClass" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman';" text="Join Class" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleRefreshMaterials" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman';" text="Refresh Files" />
                </HBox>

                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 28; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(20,30,60,0.08), 12, 0, 0, 5);">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="classNameLabel" style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #1f2d3d; -fx-font-family: 'Times New Roman';" text="Class Name" />
                            <Label fx:id="classIdLabel" style="-fx-font-size: 13; -fx-text-fill: #4a6fa5; -fx-font-family: 'Courier New';" text="Class ID: 0" />
                            <Label fx:id="topicLabel" style="-fx-font-size: 15; -fx-text-fill: #52616b; -fx-font-family: 'Times New Roman';" text="Topic: No topic" />
                            <Label fx:id="creatorLabel" style="-fx-font-size: 15; -fx-text-fill: #52616b; -fx-font-family: 'Times New Roman';" text="Created by: Unknown" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <MenuButton fx:id="classActionsMenu" mnemonicParsing="false" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman';" text="⋮" textFill="WHITE">
                            <items>
                                <MenuItem fx:id="deleteClassMenuItem" onAction="#handleDeleteClass" text="Delete Class" />
                                <MenuItem fx:id="leaveClassMenuItem" onAction="#handleLeaveClass" text="Leave Class" />
                            </items>
                        </MenuButton>
                    </HBox>
                </VBox>

                <VBox fx:id="uploadSection" spacing="10.0" style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(20,30,60,0.08), 10, 0, 0, 4);">
                    <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1f2d3d; -fx-font-family: 'Times New Roman';" text="Upload Class Material" />
                    <Label style="-fx-font-size: 13; -fx-text-fill: #6c7a89; -fx-font-family: 'Times New Roman';" text="Only the class creator can upload files for this class." />
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Button onAction="#handleChooseFile" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 14; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman';" text="Choose File" />
                        <Label fx:id="selectedFileLabel" style="-fx-font-size: 13; -fx-text-fill: #6c7a89; -fx-font-family: 'Times New Roman';" text="No file selected" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <ComboBox fx:id="materialTypeCombo" prefWidth="220.0" promptText="Material Type" />
                        <Button fx:id="uploadButton" onAction="#handleUploadMaterial" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman';" text="Upload" />
                    </HBox>
                    <Label fx:id="uploadProgressLabel" managed="false" style="-fx-font-size: 12; -fx-text-fill: #6c7a89; -fx-font-family: 'Times New Roman';" text="Uploading..." visible="false" />
                    <ProgressBar fx:id="uploadProgressBar" managed="false" prefWidth="340.0" progress="-1.0" visible="false" />
                </VBox>

                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(20,30,60,0.08), 10, 0, 0, 4);">
                    <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1f2d3d; -fx-font-family: 'Times New Roman';" text="Class Materials" />
                    <Label fx:id="materialsStatusLabel" style="-fx-font-size: 13; -fx-text-fill: #6c7a89; -fx-font-family: 'Times New Roman';" text="Loading files..." />
                    <VBox fx:id="materialsContainer" spacing="10.0" />
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

