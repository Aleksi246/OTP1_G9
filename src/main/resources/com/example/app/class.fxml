<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f1f5f9;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.app.ClassController">
    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20.0" style="-fx-padding: 28 32 32 32;">

                <!-- Toolbar -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Button onAction="#handleGoBack"
                            text="← Back"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-weight: bold;
                                   -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-font-size: 13px; -fx-font-family: 'Segoe UI';" />
                    <Button fx:id="joinButton" onAction="#handleJoinClass"
                            text="Join Class"
                            style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                                   -fx-effect: dropshadow(gaussian, rgba(34,197,94,0.30), 6, 0, 0, 2);" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleRefreshMaterials"
                            text="↻  Refresh"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-font-size: 13px; -fx-font-family: 'Segoe UI';" />
                </HBox>

                <!-- Class Info Card -->
                <VBox spacing="12.0"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.09), 18, 0, 0, 5);
                             -fx-padding: 28 30 28 30;">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="classNameLabel"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                                          -fx-font-family: 'Segoe UI';"
                                   text="Class Name" />
                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label fx:id="classIdLabel"
                                       style="-fx-font-size: 12px; -fx-text-fill: white; -fx-font-family: 'Segoe UI';
                                              -fx-background-color: #3b82f6; -fx-background-radius: 20;
                                              -fx-padding: 3 10; -fx-font-weight: bold;"
                                       text="ID: 0" />
                                <Label fx:id="topicLabel"
                                       style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-font-family: 'Segoe UI';"
                                       text="Topic: —" />
                            </HBox>
                            <Label fx:id="creatorLabel"
                                   style="-fx-font-size: 13px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI';"
                                   text="Created by: Unknown" />
                        </VBox>
                        <MenuButton fx:id="classActionsMenu" mnemonicParsing="false"
                                    text="⋯  Actions" textFill="WHITE"
                                    style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold;
                                           -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;
                                           -fx-font-size: 13px; -fx-font-family: 'Segoe UI';">
                            <items>
                                <MenuItem fx:id="deleteClassMenuItem" onAction="#handleDeleteClass" text="🗑  Delete Class" />
                                <MenuItem fx:id="leaveClassMenuItem" onAction="#handleLeaveClass" text="↩  Leave Class" />
                            </items>
                        </MenuButton>
                    </HBox>
                </VBox>

                <!-- Upload Section -->
                <VBox fx:id="uploadSection" spacing="14.0"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.09), 18, 0, 0, 5);
                             -fx-padding: 24 30 24 30;">
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                                  -fx-font-family: 'Segoe UI';"
                           text="📤  Upload Class Material" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI';"
                           text="Only the class creator can upload files." />

                    <Region prefHeight="1.0" maxWidth="Infinity" style="-fx-background-color: #f1f5f9;" />

                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <Button onAction="#handleChooseFile"
                                text="📁  Choose File"
                                style="-fx-background-color: #f1f5f9; -fx-text-fill: #334155; -fx-font-weight: bold;
                                       -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                                       -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-border-width: 1.5;" />
                        <Label fx:id="selectedFileLabel"
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI';"
                               text="No file selected" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <ComboBox fx:id="materialTypeCombo" prefWidth="200.0" prefHeight="38.0"
                                  promptText="Material Type"
                                  style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                                         -fx-background-radius: 8; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-border-width: 1.5;" />
                        <Button fx:id="uploadButton" onAction="#handleUploadMaterial"
                                text="Upload"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-padding: 9 20; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-font-size: 13px; -fx-font-family: 'Segoe UI';" />
                    </HBox>
                    <Label fx:id="uploadProgressLabel" managed="false" visible="false"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI';"
                           text="Uploading…" />
                    <ProgressBar fx:id="uploadProgressBar" managed="false" visible="false"
                                 prefWidth="320.0" prefHeight="8.0" progress="-1.0"
                                 style="-fx-accent: #3b82f6;" />
                </VBox>

                <!-- Materials Section -->
                <VBox spacing="14.0"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.09), 18, 0, 0, 5);
                             -fx-padding: 24 30 24 30;">
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                                  -fx-font-family: 'Segoe UI';"
                           text="📂  Class Materials" />
                    <Label fx:id="materialsStatusLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI';"
                           text="Loading files…" />
                    <VBox fx:id="materialsContainer" spacing="10.0" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

