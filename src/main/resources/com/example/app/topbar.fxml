<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<HBox alignment="CENTER_LEFT" prefHeight="56.0" prefWidth="1000.0" spacing="8.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.TopBarController">
    <padding>
        <Insets left="16.0" right="16.0" top="12.0" bottom="8.0" />
    </padding>
    <children>
        <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #f0f0f0; -fx-cursor: hand; -fx-padding: 8 12 8 12; -fx-background-radius: 5; -fx-border-radius: 5; -fx-font-size: 16px; -fx-font-weight: bold;" text="←">
        </Button>
        <Button fx:id="forwardButton" mnemonicParsing="false" onAction="#handleForward" style="-fx-background-color: #f0f0f0; -fx-cursor: hand; -fx-padding: 8 12 8 12; -fx-background-radius: 5; -fx-border-radius: 5; -fx-font-size: 16px; -fx-font-weight: bold;" text="→">
        </Button>
    </children>
</HBox>

