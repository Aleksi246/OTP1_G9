<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" prefHeight="56.0" prefWidth="1400.0" spacing="8.0" style="-fx-background-color: #ffffff; -fx-font-family: 'Times New Roman'; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 6, 0, 0, 3);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.TopBarController">
    <padding>
        <Insets bottom="8.0" left="16.0" right="16.0" top="12.0" />
    </padding>
    <children>
      <ImageView fx:id="learningPlatformImage" fitHeight="40.0" fitWidth="200.0" onMouseClicked="#handleLearningPlatformClick" pickOnBounds="true" preserveRatio="true" style="-fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 8, 0, 0, 3);">
         <image>
            <Image url="@images/ee74eea0-a591-443a-bfe7-84c3717b931f.jpg" />
         </image>
      </ImageView>
        <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #ecf0f1; -fx-cursor: hand; -fx-padding: 8 12 8 12; -fx-background-radius: 6; -fx-border-radius: 6; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Times New Roman';" text="←">
        </Button>
        <Button fx:id="forwardButton" mnemonicParsing="false" onAction="#handleForward" style="-fx-background-color: #ecf0f1; -fx-cursor: hand; -fx-padding: 8 12 8 12; -fx-background-radius: 6; -fx-border-radius: 6; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Times New Roman';" text="→">
        </Button>
      <Region prefHeight="36.0" prefWidth="852.0" />
      <Button fx:id="profileButton" alignment="CENTER" onAction="#handleSwitchToProfile" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman'; -fx-font-size: 14;" text="Profile" />
    </children>
</HBox>
