<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1200.0" spacing="14.0" style="-fx-background-color: #1e293b; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.22), 8, 0, 0, 3);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.TopBarController">
    <padding>
        <Insets bottom="10.0" left="28.0" right="28.0" top="10.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" onMouseClicked="#handleLearningPlatformClick" spacing="12.0" style="-fx-cursor: hand;">
            <VBox alignment="CENTER_LEFT" spacing="0.0">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI';" text="LearnHub" />
                <Label style="-fx-font-size: 10px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI';" text="Learning Platform" />
            </VBox>
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="profileButton" onAction="#handleSwitchToProfile" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;                        -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;                        -fx-font-family: 'Segoe UI';                        -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.4), 8, 0, 0, 2);" text="👤  My Profile" />
    </children>
</HBox>
