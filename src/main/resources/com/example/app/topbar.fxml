<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" prefHeight="106.0" prefWidth="1400.0" spacing="8.0" style="-fx-background-color: #ffffff; -fx-font-family: 'Times New Roman'; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 6, 0, 0, 3);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.TopBarController">
    <padding>
        <Insets bottom="8.0" left="16.0" right="16.0" top="12.0" />
    </padding>
    <children>
      <ImageView fx:id="learningPlatformImage" fitHeight="92.0" fitWidth="107.0" onMouseClicked="#handleLearningPlatformClick" pickOnBounds="true" preserveRatio="true" style="-fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 8, 0, 0, 3);">
         <image>
            <Image url="@images/ee74eea0-a591-443a-bfe7-84c3717b931f.jpg" />
         </image>
      </ImageView>
      <Region prefHeight="92.0" prefWidth="963.0" HBox.hgrow="ALWAYS" />
      <Button fx:id="profileButton" alignment="CENTER" onAction="#handleSwitchToProfile" prefHeight="64.0" prefWidth="145.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-family: 'Times New Roman'; -fx-font-size: 14;" text="Profile" />
    </children>
</HBox>
