<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f1f5f9;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.app.LoginController">
    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="0.0"
                  style="-fx-padding: 60 0 60 0;">

                <!-- Card -->
                <VBox alignment="CENTER_LEFT" maxWidth="460.0" spacing="22.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.10), 24, 0, 0, 8);
                             -fx-padding: 44 48 44 48;">

                    <!-- Header -->
                    <VBox spacing="6.0">
                        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                                      -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;"
                               text="%login.welcome" />
                        <Label fx:id="contextLabel"
                               style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;"
                               text="%login.subtitle" />
                    </VBox>

                    <!-- Divider -->
                    <Region prefHeight="1.0" maxWidth="Infinity"
                            style="-fx-background-color: #e2e8f0;" />

                    <!-- Inputs -->
                    <VBox spacing="14.0">
                        <VBox spacing="6.0">
                            <Label text="%login.username" style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #334155; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
                            <TextField fx:id="usernameField" prefHeight="42.0"
                                       promptText="%login.username.prompt"
                                       style="-fx-background-radius: 8; -fx-font-size: 14px;
                                              -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif; -fx-border-color: #cbd5e1;
                                              -fx-border-radius: 8; -fx-border-width: 1.5;
                                              -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                        </VBox>
                        <VBox spacing="6.0">
                            <Label text="%login.password" style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #334155; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
                            <PasswordField fx:id="passwordField" prefHeight="42.0"
                                           promptText="%login.password.prompt"
                                           style="-fx-background-radius: 8; -fx-font-size: 14px;
                                                  -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif; -fx-border-color: #cbd5e1;
                                                  -fx-border-radius: 8; -fx-border-width: 1.5;
                                                  -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                        </VBox>
                        <PasswordField fx:id="confirmPasswordField" managed="false" visible="false"
                                       prefHeight="42.0" promptText="%login.confirmPassword"
                                       style="-fx-background-radius: 8; -fx-font-size: 14px;
                                              -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif; -fx-border-color: #cbd5e1;
                                              -fx-border-radius: 8; -fx-border-width: 1.5;
                                              -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                    </VBox>

                    <!-- Error -->
                    <Label fx:id="errorLabel"
                           style="-fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;"
                           wrapText="true" />

                    <!-- Action buttons -->
                    <VBox spacing="12.0">
                        <Button fx:id="primaryActionButton" maxWidth="Infinity"
                                onAction="#handlePrimaryAction" prefHeight="44.0"
                                text="%login.signIn"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white;
                                       -fx-background-radius: 9; -fx-cursor: hand;
                                       -fx-font-weight: bold; -fx-font-size: 15px;
                                       -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                       -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.35), 8, 0, 0, 3);" />

                        <HBox alignment="CENTER" spacing="6.0">
                            <Label fx:id="switchContextLabel"
                                   style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;"
                                   text="%login.noAccount" />
                            <Button fx:id="switchActionButton" onAction="#handleSwitchContext"
                                    text="%login.registerNow"
                                    style="-fx-background-color: transparent; -fx-text-fill: #3b82f6;
                                           -fx-padding: 0; -fx-cursor: hand; -fx-font-weight: bold;
                                           -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
