<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" prefHeight="400.0" prefWidth="540.0" spacing="14.0"
      style="-fx-background-color: white; -fx-background-radius: 14;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.app.ViewReviewsDialogController">
    <padding>
        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
    </padding>

    <!-- Header -->
    <VBox spacing="4.0">
        <Label text="📋  Material Reviews"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                      -fx-font-family: 'Segoe UI';" />
        <Label text="File:" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI';" />
        <Label fx:id="materialNameLabel" wrapText="true"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;
                      -fx-font-family: 'Segoe UI';" />
    </VBox>

    <Region prefHeight="1.0" maxWidth="Infinity" style="-fx-background-color: #e2e8f0;" />

    <Label fx:id="statusLabel" wrapText="true"
           style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-family: 'Segoe UI';" />

    <ListView fx:id="reviewsListView" prefHeight="240.0" VBox.vgrow="ALWAYS"
              style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                     -fx-background-radius: 10; -fx-border-color: #e2e8f0;
                     -fx-border-radius: 10; -fx-border-width: 1.5;
                     -fx-background-color: #f8fafc;" />

    <HBox alignment="CENTER_RIGHT">
        <Button mnemonicParsing="false" onAction="#handleClose" prefHeight="38.0" prefWidth="90.0"
                text="Close"
                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;
                       -fx-font-family: 'Segoe UI';" />
    </HBox>
</VBox>

