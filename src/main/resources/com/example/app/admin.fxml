<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane minHeight="900.0" minWidth="1400.0" style="-fx-background-color: #f5f7fa; -fx-font-family: 'Times New Roman';" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.AdminController">
    <top>
        <fx:include source="topbar.fxml" />
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <HBox spacing="10">
                <Label text="Admin Dashboard" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 18; -fx-font-weight: bold;" />
                <Button text="Logout" onAction="#handleLogout" style="-fx-font-family: 'Times New Roman'; -fx-background-radius: 6;" />
            </HBox>

            <Label text="Register New Teacher" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 14; -fx-font-weight: bold;" />

            <TextField fx:id="teacherUsernameField" promptText="Teacher Username" style="-fx-font-family: 'Times New Roman'; -fx-background-radius: 6;" />
            <TextField fx:id="teacherPasswordField" promptText="Teacher Password" style="-fx-font-family: 'Times New Roman'; -fx-background-radius: 6;" />

            <Button text="Create Teacher" onAction="#handleCreateTeacher" style="-fx-font-family: 'Times New Roman'; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6;" />

            <Label fx:id="statusLabel" text="" wrapText="true" style="-fx-font-family: 'Times New Roman';" />
            <Label fx:id="errorLabel" text="" wrapText="true" style="-fx-font-family: 'Times New Roman';" />
        </VBox>
    </center>
</BorderPane>
