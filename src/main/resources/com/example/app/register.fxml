<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f1f5f9;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.app.RegisterController">
    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="0.0" style="-fx-padding: 60 0 60 0;">

                <!-- Card -->
                <VBox alignment="CENTER_LEFT" maxWidth="480.0" spacing="20.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.10), 24, 0, 0, 8);
                             -fx-padding: 44 48 44 48;">

                    <!-- Header -->
                    <VBox spacing="6.0">
                        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                                      -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;"
                               text="%register.title" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;"
                               text="%register.subtitle" />
                    </VBox>

                    <Region prefHeight="1.0" maxWidth="Infinity" style="-fx-background-color: #e2e8f0;" />

                    <!-- Fields -->
                    <VBox spacing="14.0">
                        <VBox spacing="6.0">
                            <Label text="%register.username" style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #334155; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
                            <TextField fx:id="usernameField" prefHeight="42.0" promptText="%register.username.prompt"
                                       style="-fx-background-radius: 8; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                              -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-border-width: 1.5;
                                              -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                        </VBox>
                        <VBox spacing="6.0">
                            <Label text="%register.email" style="-fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-text-fill: #334155; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
                            <TextField fx:id="emailField" prefHeight="42.0" promptText="%register.email.prompt"
                                       style="-fx-background-radius: 8; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                              -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-border-width: 1.5;
                                              -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                        </VBox>
                        <VBox spacing="6.0">
                            <Label text="%register.password" style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #334155; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
                            <StackPane alignment="CENTER_RIGHT">
                                <PasswordField fx:id="passwordField" prefHeight="42.0" promptText="%register.password.prompt"
                                               style="-fx-background-radius: 8; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                                      -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-border-width: 1.5;
                                                      -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                                <TextField fx:id="passwordTextField" managed="false" visible="false" prefHeight="42.0"
                                           style="-fx-background-radius: 8; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                                  -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-border-width: 1.5;
                                                  -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                                <Button fx:id="toggleButton" onAction="#togglePassword" text="Show"
                                        style="-fx-background-color: transparent; -fx-cursor: hand;
                                               -fx-text-fill: #94a3b8; -fx-font-size: 15px; -fx-padding: 0 10 0 0;" />
                            </StackPane>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label text="%register.confirmPassword" style="-fx-font-size: 13px; -fx-font-weight: bold;
                                              -fx-text-fill: #334155; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
                            <PasswordField fx:id="confirmPasswordField" prefHeight="42.0" promptText="%register.confirmPassword.prompt"
                                           style="-fx-background-radius: 8; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                                  -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-border-width: 1.5;
                                                  -fx-background-color: #f8fafc; -fx-padding: 0 12;" />
                        </VBox>
                    </VBox>

                    <Label fx:id="messageLabel" minHeight="16.0" wrapText="true"
                           style="-fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />

                    <VBox spacing="12.0">
                        <Button fx:id="registerButton" maxWidth="Infinity" onAction="#handleRegister"
                                prefHeight="44.0" text="%register.createAccount"
                                style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-background-radius: 9; -fx-cursor: hand; -fx-font-size: 15px;
                                       -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                       -fx-effect: dropshadow(gaussian, rgba(34,197,94,0.35), 8, 0, 0, 3);" />
                        <HBox alignment="CENTER" spacing="6.0">
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;"
                                   text="%register.alreadyAccount" />
                            <Hyperlink onAction="#handleSwitchContext" text="%register.signIn"
                                       style="-fx-text-fill: #3b82f6; -fx-font-weight: bold;
                                              -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                                              -fx-border-color: transparent;" />
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
