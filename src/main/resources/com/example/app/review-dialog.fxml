<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" prefHeight="320.0" prefWidth="420.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.app.ReviewDialogController"
      style="-fx-background-color: white;">
    <padding>
        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
    </padding>

    <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Review Material"/>
    <Label text="File:"/>
    <Label fx:id="materialNameLabel" style="-fx-font-size: 13; -fx-text-fill: #2c3e50;" wrapText="true"/>

    <Label text="Rating (1-5)"/>
    <ComboBox fx:id="ratingCombo" prefWidth="120.0"/>

    <Label text="Comment"/>
    <TextArea fx:id="commentTextArea" prefHeight="140.0" promptText="Share your feedback..." wrapText="true"/>

    <Label fx:id="validationLabel" style="-fx-text-fill: #e74c3c;" wrapText="true"/>

    <HBox alignment="CENTER_RIGHT" spacing="8.0">
        <Button mnemonicParsing="false" onAction="#handleCancel" text="Cancel"/>
        <Button mnemonicParsing="false" onAction="#handleSubmit" text="Submit Review"/>
    </HBox>
</VBox>

