<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" prefHeight="360.0" prefWidth="440.0" spacing="14.0"
      style="-fx-background-color: white; -fx-background-radius: 14;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.app.ReviewDialogController">
    <padding>
        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
    </padding>

    <!-- Header -->
    <VBox spacing="4.0">
        <Label text="%review.title"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                      -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
        <Label text="%review.file" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
        <Label fx:id="materialNameLabel" wrapText="true"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;
                      -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
    </VBox>

    <Region prefHeight="1.0" maxWidth="Infinity" style="-fx-background-color: #e2e8f0;" />

    <!-- Rating -->
    <VBox spacing="6.0">
        <Label text="%review.rating"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;
                      -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
        <ComboBox fx:id="ratingCombo" prefWidth="140.0" prefHeight="38.0"
                  style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                         -fx-background-radius: 8; -fx-border-color: #cbd5e1;
                         -fx-border-radius: 8; -fx-border-width: 1.5;" />
    </VBox>

    <!-- Comment -->
    <VBox spacing="6.0" VBox.vgrow="ALWAYS">
        <Label text="%review.comment"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;
                      -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
        <TextArea fx:id="commentTextArea" prefHeight="120.0" prefWidth="Infinity"
                  promptText="%review.comment.prompt" wrapText="true"
                  style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;
                         -fx-background-radius: 8; -fx-border-color: #cbd5e1;
                         -fx-border-radius: 8; -fx-border-width: 1.5;
                         -fx-background-color: #f8fafc; -fx-padding: 8 12;" />
    </VBox>

    <Label fx:id="validationLabel" wrapText="true"
           style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="38.0" prefWidth="90.0"
                text="%review.cancel"
                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;
                       -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
        <Button mnemonicParsing="false" onAction="#handleSubmit" prefHeight="38.0" prefWidth="140.0"
                text="%review.submit"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;
                       -fx-font-family: 'Segoe UI', 'Noto Sans Arabic', 'Noto Naskh Arabic', 'Noto Color Emoji', sans-serif;" />
    </HBox>
</VBox>

