<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f1f5f9;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.app.HomeController">
    <top>
        <fx:include source="topbar.fxml" />
    </top>

    <center>
        <VBox spacing="0.0" style="-fx-background-color: #f1f5f9;">

            <!-- Page header bar -->
            <HBox alignment="CENTER_LEFT" spacing="16.0"
                  style="-fx-background-color: white; -fx-padding: 20 32 20 32;
                         -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="welcomeLabel"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                                  -fx-font-family: 'Segoe UI';"
                           text="%home.welcome" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI';"
                           text="%home.subtitle" />
                </VBox>
                <MenuButton mnemonicParsing="false" prefHeight="40.0" prefWidth="160.0"
                            text="%home.manageClasses" textFill="WHITE"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 9; -fx-cursor: hand; -fx-font-size: 13px;
                                   -fx-font-family: 'Segoe UI';
                                   -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.32), 6, 0, 0, 2);">
                    <items>
                        <MenuItem onAction="#handleJoinClass" text="%home.joinClass" />
                        <MenuItem onAction="#handleCreateClass" text="%home.createClass" />
                    </items>
                </MenuButton>
            </HBox>

            <!-- Loading label -->
            <Label fx:id="loadingLabel" text="%home.loadingClasses"
                   style="-fx-font-size: 14px; -fx-text-fill: #94a3b8; -fx-font-family: 'Segoe UI';
                          -fx-padding: 20 32 0 32;" />

            <!-- Classes grid -->
            <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <FlowPane fx:id="classesContainer" alignment="TOP_CENTER"
                          columnHalignment="CENTER" hgap="24.0" vgap="24.0"
                          style="-fx-padding: 28 32 32 32; -fx-background-color: transparent;" />
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
